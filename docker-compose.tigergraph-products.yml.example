# =============================================================================
# REFERENCE ONLY — NOT USED BY THIS PLATFORM.
# =============================================================================
#
# This file used to be `docker-compose.yml`. It was renamed because it brings
# up TigerGraph's OFFICIAL CopilotGraph product stack
# (tigergraph/graphrag, tigergraph/graphrag-ui, tigergraph/chat-history,
# tigergraph/graphrag-ecc) — NOT this platform's orchestrator + dashboard.
#
# Running `docker compose -f docker-compose.tigergraph-products.yml.example up`
# will NOT start the Shadow Network Intelligence orchestrator or dashboard.
# It is kept as a reference for engineers who want to stand up TigerGraph
# Community + CopilotGraph locally for comparison.
#
# To deploy THIS platform, use the real `docker-compose.yml` at the repo root
# or `make dev-backend` + `make dev-frontend` (see README).
#
# =============================================================================

services:
  # TigerGraph Database (self-contained)
  tigergraph:
    image: tigergraph/community:4.2.2
    container_name: shadow_tigergraph
    platform: linux/amd64
    ports:
      - "14240:14240"
      - "9000:9000"
    environment:
      - LICENSE_TYPE=binary
    volumes:
      - tigergraph_data:/home/tigergraph/tigergraph/data
    networks:
      - shadow_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:14240"]
      interval: 30s
      timeout: 10s
      retries: 5

  # Ollama (Local LLM - free, no API keys)
  ollama:
    image: ollama/ollama:latest
    container_name: shadow_ollama
    platform: linux/amd64
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    networks:
      - shadow_network
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]

  # GraphRAG API Server
  graphrag:
    image: tigergraph/graphrag:latest
    container_name: shadow_graphrag
    platform: linux/amd64
    ports:
      - "8000:8000"
    depends_on:
      - tigergraph
      - ollama
    environment:
      - SERVER_CONFIG=/code/configs/server_config.json
      - LOGLEVEL=INFO
      - USE_CYPHER=false
      - INIT_EMBED_STORE=true
      - PRODUCTION=false
    volumes:
      - ./configs:/code/configs
      - ./libs:/code/libs
    networks:
      - shadow_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  # Eventual Consistency Checker (async processing)
  graphrag-ecc:
    image: tigergraph/graphrag-ecc:latest
    container_name: shadow_graphrag_ecc
    platform: linux/amd64
    ports:
      - "8001:8001"
    depends_on:
      - tigergraph
    environment:
      - SERVER_CONFIG=/code/configs/server_config.json
      - LOGLEVEL=INFO
      - INIT_EMBED_STORE=false
    volumes:
      - ./configs:/code/configs
    networks:
      - shadow_network

  # Chat History Service
  chat-history:
    image: tigergraph/chat-history:latest
    container_name: shadow_chat_history
    platform: linux/amd64
    ports:
      - "8002:8002"
    environment:
      - CONFIG_FILES=/configs/server_config.json
      - LOGLEVEL=INFO
    volumes:
      - ./configs:/configs
    networks:
      - shadow_network

  # Dashboard UI
  graphrag-ui:
    image: tigergraph/graphrag-ui:latest
    container_name: shadow_graphrag_ui
    platform: linux/amd64
    ports:
      - "3000:3000"
    depends_on:
      - graphrag
    networks:
      - shadow_network

  # Nginx Reverse Proxy
  nginx:
    image: nginx:latest
    container_name: shadow_nginx
    ports:
      - "80:80"
    volumes:
      - ./configs/nginx.conf:/etc/nginx/conf.d/default.conf
    depends_on:
      - graphrag-ui
      - graphrag
    networks:
      - shadow_network

  # Prometheus Monitoring (optional)
  prometheus:
    image: prom/prometheus:latest
    container_name: shadow_prometheus
    ports:
      - "9090:9090"
    volumes:
      - ./9_devops/monitoring/prometheus.yml:/etc/prometheus/prometheus.yml
      - prometheus_data:/prometheus
    networks:
      - shadow_network
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'

networks:
  shadow_network:
    driver: bridge

volumes:
  tigergraph_data:
  ollama_data:
  prometheus_data:
