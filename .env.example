# ───────────────────────────────────────────────────────────────────────
# Shadow Network Intelligence — environment template
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# REQUIRED  — the platform won't reach TigerGraph or NIM without these
# OPTIONAL  — safe defaults exist; override only when needed
# ───────────────────────────────────────────────────────────────────────


# ── REQUIRED ──────────────────────────────────────────────────────────
# TigerGraph Cloud connection. The canonical auth path is
# TIGERGRAPH_GSQL_SECRET (RESTPP secret from TG portal →
# Graph Settings → RESTpp). `3_graph_intelligence_core/clients/graph_client.py`
# uses pyTigerGraph's native cloud auth (gsqlSecret + tgCloud=True).
# When the secret is unset, the client falls back to username/password.
# When TG is unreachable, it falls back to the local CSV dataset
# (see docs/ARCHITECTURE.md "Offline fallback" + 10_research/09_failure_cases.md).
TIGERGRAPH_HOST=https://your-instance.tg-xxxxxxx.i.tgcloud.io
TIGERGRAPH_GRAPH=ShadowGraph
TIGERGRAPH_GSQL_SECRET=your-restpp-secret

# Legacy fallback (only used if GSQL_SECRET is empty):
TIGERGRAPH_USERNAME=your-email@example.com
TIGERGRAPH_PASSWORD=your-tigergraph-password
TIGERGRAPH_RESTPP_PORT=443
TIGERGRAPH_HTTPS=true


# ── EMBEDDINGS + LLM ──────────────────────────────────────────────────
# NVIDIA NIM is the default embedder provider. Without a key the
# benchmark runner silently falls back to deterministic mock embeddings.
# Get your key from: https://build.nvidia.com/nim
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (optional — local LLM fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional: only used by VectorRAG baseline when EMBEDDING_MODEL is set
EMBEDDING_MODEL=all-MinLM:latest
EMBEDDING_HOST=http://localhost:11434


# ── DATA PROFILE ──────────────────────────────────────────────────────
# Which profile lives under outputs/{profile}/. Defaults to `small`
# (~25k entities). Other profiles: hackathon_default, benchmark_dense.
DATA_PROFILE=small


# ── ORCHESTRATOR (4_orchestrator_api) ─────────────────────────────────
# Prewarm: at boot, the orchestrator can warm the result cache by
# running graph traversal against the top-N entities. Off by default
# for fast development iteration; on by default for production demos.
SNI_PREWARM_ON_START=1
SNI_PREWARM_TOP_N=30
SNI_PRESET_PREWARM=0

# Result cache (LRU + TTL) wrapping engine.query.
SNI_RESULT_CACHE_ENABLED=1
SNI_RESULT_CACHE_SIZE=64
SNI_RESULT_CACHE_TTL=300

# Investigation archive — disk-backed at
# 4_orchestrator_api/outputs/investigations/. Bounded LRU prune.
SNI_INVESTIGATION_ARCHIVE_MAX=200


# ── BENCHMARK SERVICE (BenchmarkService config) ───────────────────────
# Provider knobs for `POST /benchmark/run` and `POST /benchmark/ad-hoc`.
# Defaults to deterministic mock everywhere so the benchmark sweep is
# reproducible and costs nothing. Override for real provider runs.
SNI_BENCHMARK_VECTOR_PROVIDER=mock
SNI_BENCHMARK_GRAPH_PROVIDER=tigergraph
SNI_BENCHMARK_LLM_PROVIDER=mock
SNI_BENCHMARK_LLM_MODEL=mock
SNI_BENCHMARK_JUDGE_PROVIDER=mock
SNI_BENCHMARK_JUDGE_MODEL=mock
SNI_BENCHMARK_TOP_K=8
SNI_BENCHMARK_CHUNK_SIZE=500


# ── FEATURE FLAGS ─────────────────────────────────────────────────────
ENABLE_HALLUCINATION_CHECK=false
ENABLE_USEFULNESS_CHECK=false


# ── FRONTEND ──────────────────────────────────────────────────────────
# These are read at Vite build time (NOT runtime).
# Both default to localhost:8000 / /api/v1 — override for prod deploys.
# Set in 8_dashboard_ui/.env (see Vite import.meta.env conventions).
#
# VITE_API_BASE_URL=http://localhost:8000
# VITE_API_PREFIX=/api/v1
