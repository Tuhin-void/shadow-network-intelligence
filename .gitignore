.DS_Store
Thumbs.db

# ----------------------------
# Project Specific
# ----------------------------

# Ignore generic data files
*.csv
*.txt

# IMPORTANT:
# Allow JSON files
!*.json

# Allow project datasets
!shadow_network_sample_dataset/**/*.csv
!shadow_network_sample_dataset/**/*.json
!shadow_network_sample_dataset/**/*.md

# Allow demo/mock/cache JSONs
!demo_data/**/*.json
!demo_data/**/*.csv
!cache/**/*.json
!mock_responses/**/*.json

# ----------------------------
# Logs
# ----------------------------
*.log
logs/

# ----------------------------
# Database
# ----------------------------
*.db
*.sqlite3

# ----------------------------
# Environment
# ----------------------------
.env
.env.local

# ----------------------------
# Docker
# ----------------------------
.dockerignore

# ----------------------------
# Node
# ----------------------------
node_modules/
.npm/

# ----------------------------
# Build outputs (frontend + reports)
# ----------------------------

generated_reports/
8_dashboard_ui/dist/

# ----------------------------
# Runtime-generated data
# ----------------------------
# Everything under outputs/ is locally generated:
#   outputs/{profile}/csv/                — data engine output
#   outputs/{profile}/json/               — per-entity JSON
#   outputs/{profile}/enriched_corpus/    — semantic intelligence corpus (~42MB)
#   outputs/{profile}/documents/          — data_corpus_enricher dossiers
#   outputs/{profile}/chroma_db/          — VectorRAG vector store
# Regenerate with:  make generate-data && make enrich-corpus
outputs/
1_data_engine/outputs/
2_baseline_systems/outputs/
# Investigation archive (disk-backed, written by the orchestrator at runtime).
# Bounded LRU prune at SNI_INVESTIGATION_ARCHIVE_MAX entries.
4_orchestrator_api/outputs/

# Benchmark + cache artifacts
benchmark_results.json
*.benchmark
3_graph_intelligence_core/db/

# Local server config (may contain endpoints / per-instance settings)
configs/server_config.json

# ChromaDB persistence
*.bin
*.parquet

# Dashboard local env (per-developer Vite env overrides)
8_dashboard_ui/.env
8_dashboard_ui/.env.local

# ----------------------------
# Exceptions — keep these tracked
# ----------------------------
# `outputs/` is ignored globally, but the shadow_network_sample_dataset
# and demo/mock JSON fixtures used by the platform must stay in git.
# Negation rules are matched bottom-up, so these belong here.
!shadow_network_sample_dataset/**
!demo_data/**
!mock_responses/**

